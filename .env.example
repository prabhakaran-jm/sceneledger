# ---------- Storage ----------

# local = filesystem under .sceneledger/ (offline dev) | b2 = Backblaze B2 (intended hackathon path)
SCENELEDGER_STORAGE_BACKEND=b2

# Static B2 object key prefix (not multi-tenant management)
SCENELEDGER_B2_TENANT_PREFIX=tenants/demo

# S3-compatible endpoint WITHOUT bucket name, e.g. https://s3.us-west-004.backblazeb2.com
B2_ENDPOINT=
B2_REGION=
B2_BUCKET=
B2_KEY_ID=
B2_APPLICATION_KEY=

# ---------- Media generation ----------

# genblaze = AI plan + storyboard + TTS narration via the Genblaze SDK (intended hackathon path)
# placeholder = deterministic assets, no provider keys (offline fallback)
SCENELEDGER_MEDIA_MODE=genblaze

# Required for genblaze mode (also install: pip install -r apps/api/requirements-genblaze.txt)
OPENAI_API_KEY=

# Genblaze model overrides (defaults shown)
SCENELEDGER_GENBLAZE_CHAT_MODEL=gpt-4o-mini
SCENELEDGER_GENBLAZE_IMAGE_MODEL=gpt-image-1
SCENELEDGER_GENBLAZE_TTS_MODEL=gpt-4o-mini-tts
SCENELEDGER_GENBLAZE_TTS_VOICE=alloy

# ---------- App ----------

# Comma-separated browser origins allowed to call the API (hosted frontend + local dev)
SCENELEDGER_CORS_ORIGINS=http://localhost:3000

# Frontend build-time var (set in Vercel / apps/web/.env.local, not read by the API):
# NEXT_PUBLIC_API_URL=https://your-api.example.com
