# SceneLedger storage and media



# local = filesystem under .sceneledger/ (default, no B2 credentials needed)

# b2 = Backblaze B2 via S3-compatible API (optional for M1)

SCENELEDGER_STORAGE_BACKEND=local



# B2 object key prefix only — not multi-tenant management (default: tenants/demo)

SCENELEDGER_B2_TENANT_PREFIX=tenants/demo



# S3-compatible endpoint WITHOUT bucket name, e.g. https://s3.us-west-004.backblazeb2.com

B2_ENDPOINT=

B2_REGION=

B2_BUCKET=

B2_KEY_ID=

B2_APPLICATION_KEY=



# Media generation (M2)

# placeholder = deterministic assets, no provider keys (default)

# genblaze = optional Genblaze adapter (requires pip install -r requirements-genblaze.txt)

SCENELEDGER_MEDIA_MODE=placeholder



# OpenAI image model for Genblaze storyboard (default: gpt-image-1)

# SCENELEDGER_GENBLAZE_IMAGE_MODEL=gpt-image-1

# Genblaze chat model for AI scene planning (default: gpt-4o-mini)

# SCENELEDGER_GENBLAZE_CHAT_MODEL=gpt-4o-mini

# Genblaze OpenAI TTS narration (defaults: gpt-4o-mini-tts, alloy)

# SCENELEDGER_GENBLAZE_TTS_MODEL=gpt-4o-mini-tts

# SCENELEDGER_GENBLAZE_TTS_VOICE=alloy



# Provider keys (genblaze mode only — not required for placeholder)

GENBLAZE_STORAGE_PROVIDER=b2

GMI_API_KEY=

OPENAI_API_KEY=

ELEVENLABS_API_KEY=



# App

APP_ENV=development

# Comma-separated browser origins for hosted frontend (default: http://localhost:3000)

# SCENELEDGER_CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

DATABASE_URL=sqlite:///./sceneledger.db

