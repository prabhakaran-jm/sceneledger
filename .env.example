# SceneLedger storage

# local = filesystem under .sceneledger/ (default, no B2 credentials needed)
# b2 = Backblaze B2 via S3-compatible API (optional for M1)
SCENELEDGER_STORAGE_BACKEND=local

# B2 object key prefix only — not multi-tenant management (default: tenants/demo)
SCENELEDGER_B2_TENANT_PREFIX=tenants/demo

# S3-compatible endpoint WITHOUT bucket name, e.g. https://s3.us-west-004.backblazeb2.com
B2_ENDPOINT=
B2_REGION=
B2_BUCKET=
B2_KEY_ID=
B2_APPLICATION_KEY=

# Genblaze / provider keys (M2 — not used in M1)
GENBLAZE_STORAGE_PROVIDER=b2
GMI_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# App
APP_ENV=development
DATABASE_URL=sqlite:///./sceneledger.db
